# ── Clerk (Auth + Organizations) ────────────────────────────────────────────
# Sign up at https://clerk.com → Create application → copy keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Redirect URLs (Clerk uses these for sign-in/sign-up flows)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Supabase / PostgreSQL (Database) ────────────────────────────────────────
# Sign up at https://supabase.com → New project → Settings → Database
# Use the "Transaction" pooler URL for DATABASE_URL (port 6543)
# Use the "Session" pooler or direct URL for DIRECT_URL (port 5432)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
